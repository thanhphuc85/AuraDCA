# Circle API key from https://console.circle.com/api-keys
CIRCLE_API_KEY=your-circle-api-key

# Entity secret registered for Developer-Controlled Wallets in the Circle Console.
# NEVER commit a real value.
CIRCLE_ENTITY_SECRET=your-circle-entity-secret

# Developer-Controlled Wallet id on Arc Testnet, created via:
#   npm run create-wallet
WALLET_ID=your-wallet-id

# Circle Swap Kit key from Circle Developer Console
KIT_KEY=your-circle-swap-kit-key

# Anthropic API key used for the daily DCA decision call AND the dashboard chat
# assistant (api/chat.ts on Vercel). Set this in Vercel env vars to enable chat.
ANTHROPIC_API_KEY=your-anthropic-api-key

# Guardrails (all amounts are decimal USDC strings)
MAX_DAILY_USDC=1.00
MIN_USDC_RESERVE=0.50
MIN_SWAP_USDC=0.10
CAMPAIGN_TOTAL_BUDGET_USDC=
CAMPAIGN_DURATION_DAYS=

# Set to "true" to skip the real swap call and just log what would happen
DRY_RUN=true

# --- On-chain audit anchor (contracts/AuraAttestation.sol) ---
# After each run the agent records keccak256(data/ledger.json) in this contract,
# so the committed audit trail is verifiable on-chain. Both OFF by default:
# nothing happens until you deploy the contract and flip ATTESTATION_ENABLED.
# Deploy + verify steps: contracts/README.md.
ATTESTATION_CONTRACT=
ATTESTATION_ENABLED=false

# Non-custodial allowance model: agent pulls USDC from each user's wallet via
# transferFrom (user approves an allowance on the dashboard) instead of a pooled
# deposit. Off by default. Turn on only after users have approved allowances.
ALLOWANCE_MODE=false

# --- Dip-buying ladder (Phase 1) ---
# Deeper drawdown tiers buy more. Thresholds are drawdown-from-high fractions,
# multipliers scale the base amount. All optional (defaults shown).
DCA_BASE_AMOUNT=1.00
DCA_DIP_MILD_THRESHOLD=0.05
DCA_DIP_MODERATE_THRESHOLD=0.10
DCA_DIP_STRONG_THRESHOLD=0.20
DCA_DIP_DEEP_THRESHOLD=0.30
DCA_DIP_MILD_MULTIPLIER=1.2
DCA_DIP_MODERATE_MULTIPLIER=1.5
DCA_DIP_STRONG_MULTIPLIER=2.0
DCA_DIP_DEEP_MULTIPLIER=2.5
# When recent volatility is high, widen every tier threshold by this factor.
DCA_LADDER_VOL_WIDEN=1.3
# The deepest tier never allocates more than this fraction of available balance.
DCA_LADDER_MAX_BALANCE_FRACTION=0.5

# --- Withdrawal API (api/withdraw.ts, deployed on Vercel) ---
# GitHub token with Contents:read/write on this repo, used to commit ledger
# balance updates after a withdrawal. See DEPLOY.md.
GH_PAT=your-github-pat
# The withdrawal API reads CIRCLE_WALLET_ID, falling back to WALLET_ID above.
CIRCLE_WALLET_ID=your-wallet-id

# --- Welcome email (api/send-welcome.ts) ---
# API key from https://resend.com/api-keys — used to send a real welcome email
# when a user signs up with their email on the dashboard.
RESEND_API_KEY=your-resend-api-key
# Optional sender. Defaults to Resend's shared "onboarding@resend.dev", which
# only delivers to your own Resend account email until you verify a domain.
# After verifying a domain in Resend, set this to e.g. "Aura DCA <hi@yourdomain.com>".
RESEND_FROM=
