# Circle API key from https://console.circle.com/api-keys
CIRCLE_API_KEY=your-circle-api-key

# Entity secret registered for Developer-Controlled Wallets in the Circle Console.
# NEVER commit a real value.
CIRCLE_ENTITY_SECRET=your-circle-entity-secret

# Developer-Controlled Wallet id on Arc Testnet, created via:
#   npm run create-wallet
WALLET_ID=your-wallet-id

# Circle Swap Kit key from Circle Developer Console
KIT_KEY=your-circle-swap-kit-key

# Anthropic API key used for the daily DCA decision call
ANTHROPIC_API_KEY=your-anthropic-api-key

# Guardrails (all amounts are decimal USDC strings)
MAX_DAILY_USDC=1.00
MIN_USDC_RESERVE=0.50
MIN_SWAP_USDC=0.10
CAMPAIGN_TOTAL_BUDGET_USDC=
CAMPAIGN_DURATION_DAYS=

# Set to "true" to skip the real swap call and just log what would happen
DRY_RUN=true
